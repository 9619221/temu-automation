{
  "manifest_version": 3,
  "name": "Temu 多店监控",
  "version": "0.3.37",
  "key": "",
  "description": "在 Temu 卖家后台后台抓取业务接口数据并上传云端，供多店统一汇总。",
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://erp.temu.chat/*",
    "https://agentseller.temu.com/*",
    "https://agentseller-us.temu.com/*",
    "https://agentseller-eu.temu.com/*",
    "https://seller.kuajingmaihuo.com/*",
    "https://*.erp321.com/*",
    "https://*.jushuitan.com/*",
    "https://*.scm121.com/*",
    "https://*.feishu.cn/*",
    "https://*.pftk.temu.com/*",
    "https://pftk-cn.kuajingmaihuo.com/*",
    "https://thtk-us.seller.temu.com/*"
  ],
  "background": {
    "service_worker": "web/background/sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://agentseller.temu.com/*",
        "https://agentseller-us.temu.com/*",
        "https://agentseller-eu.temu.com/*",
        "https://seller.kuajingmaihuo.com/*",
        "https://*.erp321.com/*",
        "https://*.jushuitan.com/*",
        "https://*.scm121.com/*",
        "https://*.feishu.cn/*",
        "https://*.pftk.temu.com/*",
        "https://pftk-cn.kuajingmaihuo.com/*",
        "https://thtk-us.seller.temu.com/*"
      ],
      "js": [
        "web/content/_config.generated.js",
        "web/content/bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "web/popup/popup.html",
    "default_title": "Temu 多店监控",
    "default_icon": {
      "16": "web/img/16.png",
      "48": "web/img/48.png",
      "128": "web/img/128.png"
    }
  },
  "options_page": "web/options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["web/page/hook.js"],
      "matches": [
        "https://agentseller.temu.com/*",
        "https://agentseller-us.temu.com/*",
        "https://agentseller-eu.temu.com/*",
        "https://seller.kuajingmaihuo.com/*",
        "https://*.erp321.com/*",
        "https://*.jushuitan.com/*",
        "https://*.scm121.com/*",
        "https://*.feishu.cn/*",
        "https://*.pftk.temu.com/*",
        "https://pftk-cn.kuajingmaihuo.com/*",
        "https://thtk-us.seller.temu.com/*"
      ]
    }
  ]
}
