{
  "manifest_version": 3,
  "name": "Temu 多店监控",
  "version": "0.3.40",
  "key": "",
  "description": "在 Temu 卖家后台后台抓取业务接口数据并上传云端，供多店统一汇总。",
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "tabs",
    "windows",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://erp.temu.chat/*",
    "https://agentseller.temu.com/*",
    "https://agentseller-us.temu.com/*",
    "https://agentseller-eu.temu.com/*",
    "https://seller.kuajingmaihuo.com/*",
    "https://*.erp321.com/*",
    "https://*.jushuitan.com/*",
    "https://*.scm121.com/*",
    "https://*.feishu.cn/*",
    "https://*.pftk.temu.com/*",
    "https://pftk-cn.kuajingmaihuo.com/*",
    "https://thtk-us.seller.temu.com/*"
  ],
  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://agentseller.temu.com/*",
        "https://agentseller-us.temu.com/*",
        "https://agentseller-eu.temu.com/*",
        "https://seller.kuajingmaihuo.com/*",
        "https://*.erp321.com/*",
        "https://*.jushuitan.com/*",
        "https://*.scm121.com/*",
        "https://*.feishu.cn/*",
        "https://*.pftk.temu.com/*",
        "https://pftk-cn.kuajingmaihuo.com/*",
        "https://thtk-us.seller.temu.com/*"
      ],
      "js": [
        "content/_config.generated.js",
        "content/bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Temu 多店监控",
    "default_icon": {
      "16": "img/16.png",
      "48": "img/48.png",
      "128": "img/128.png"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_csp",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "options_page": "options/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "page/hook.js"
      ],
      "matches": [
        "https://agentseller.temu.com/*",
        "https://agentseller-us.temu.com/*",
        "https://agentseller-eu.temu.com/*",
        "https://seller.kuajingmaihuo.com/*",
        "https://*.erp321.com/*",
        "https://*.jushuitan.com/*",
        "https://*.scm121.com/*",
        "https://*.feishu.cn/*",
        "https://*.pftk.temu.com/*",
        "https://pftk-cn.kuajingmaihuo.com/*",
        "https://thtk-us.seller.temu.com/*"
      ]
    }
  ]
}
